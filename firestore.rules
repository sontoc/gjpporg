rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'sonfrom@gmail.com' || 
        request.auth.token.email == 'son3u@daum.net' || 
        request.auth.token.email == 'gjpp4u@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Post Validation ---
    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorName', 'authorId', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 6 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt == request.time;
    }

    // --- Notice Validation ---
    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'content', 'authorName', 'authorId', 'priority', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 7 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000 &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.priority is bool &&
             data.createdAt is timestamp &&
             data.updatedAt == request.time;
    }

    // --- Video Validation ---
    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'description', 'youtubeUrl', 'thumbnail', 'authorName', 'authorId', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 8 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.youtubeUrl is string && data.youtubeUrl.size() <= 500 &&
             (data.thumbnail == null || (data.thumbnail is string && data.thumbnail.size() <= 1000)) &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt == request.time;
    }

    // --- Event Validation ---
    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'type', 'description', 'status', 'startDate', 'endDate', 'time', 'location', 'authorId', 'authorName', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.type is string && (data.type == 'event' || data.type == 'campaign') &&
             data.description is string && data.description.size() <= 20000 &&
             data.status is string && (data.status == 'scheduled' || data.status == 'active' || data.status == 'completed') &&
             data.startDate is string && data.startDate.size() <= 20 &&
             data.endDate is string && data.endDate.size() <= 20 &&
             data.time is string && data.time.size() <= 200 &&
             data.location is string && data.location.size() <= 300 &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000)) &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.authorName is string && data.authorName.size() <= 100 &&
             data.createdAt is timestamp &&
             data.updatedAt == request.time;
    }

    // --- RSVP Validation ---
    function isValidRsvp(data, eventId) {
      return data.keys().hasAll(['eventId', 'name', 'phone', 'email', 'createdAt']) &&
             data.eventId is string && data.eventId == eventId &&
             data.name is string && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() <= 50 &&
             data.email is string && data.email.size() <= 150 &&
             (!('message' in data) || (data.message is string && data.message.size() <= 1000)) &&
             (!('userId' in data) || (data.userId is string && data.userId.size() <= 128)) &&
             data.createdAt is timestamp;
    }

    match /posts/{postId} {
      allow get: if isValidId(postId);
      allow list: if true; 

      allow create: if isSignedIn() && isValidId(postId) && 
                      incoming().createdAt == request.time &&
                      isValidPost(incoming());
      
      allow update: if isSignedIn() && isValidId(postId) && 
                      incoming().authorId == existing().authorId &&
                      incoming().createdAt == existing().createdAt &&
                      isValidPost(incoming()) && (
                        (request.auth.uid == existing().authorId && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt']))
                      );
                      
      allow delete: if isSignedIn() && isValidId(postId) && request.auth.uid == existing().authorId;
    }

    match /notices/{noticeId} {
      allow get: if isValidId(noticeId);
      allow list: if true;

      allow create: if isAdmin() && isValidId(noticeId) && 
                      incoming().createdAt == request.time &&
                      isValidNotice(incoming());
      
      allow update: if isAdmin() && isValidId(noticeId) && 
                      incoming().authorId == existing().authorId &&
                      incoming().createdAt == existing().createdAt &&
                      isValidNotice(incoming()) && (
                        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'priority', 'updatedAt'])
                      );
                      
      allow delete: if isAdmin() && isValidId(noticeId);
    }

    match /videos/{videoId} {
      allow get: if isValidId(videoId);
      allow list: if true;

      allow create: if isAdmin() && isValidId(videoId) && 
                      incoming().createdAt == request.time &&
                      isValidVideo(incoming());
      
      allow update: if isAdmin() && isValidId(videoId) && 
                      incoming().authorId == existing().authorId &&
                      incoming().createdAt == existing().createdAt &&
                      isValidVideo(incoming()) && (
                        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'youtubeUrl', 'thumbnail', 'updatedAt'])
                      );
                      
      allow delete: if isAdmin() && isValidId(videoId);
    }

    // --- Events & Campaigns ---
    match /events/{eventId} {
      allow get: if isValidId(eventId);
      allow list: if true;

      allow create: if isAdmin() && isValidId(eventId) &&
                      incoming().createdAt == request.time &&
                      isValidEvent(incoming());

      allow update: if isAdmin() && isValidId(eventId) &&
                      incoming().authorId == existing().authorId &&
                      incoming().createdAt == existing().createdAt &&
                      isValidEvent(incoming()) && (
                        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'type', 'description', 'status', 'startDate', 'endDate', 'time', 'location', 'imageUrl', 'updatedAt'])
                      );

      allow delete: if isAdmin() && isValidId(eventId);

      // --- RSVPs Subcollection ---
      match /rsvps/{rsvpId} {
        allow get: if isValidId(rsvpId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid));
        allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

        allow create: if isValidId(rsvpId) &&
                        incoming().createdAt == request.time &&
                        isValidRsvp(incoming(), eventId);

        // RSVPs are typically immutable after registration, but if needed, owner/admin can delete
        allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      }
    }
  }
}
