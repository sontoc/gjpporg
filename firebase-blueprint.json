{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A post on the community board",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the post" },
        "content": { "type": "string", "description": "The markdown content of the post" },
        "authorName": { "type": "string", "description": "Display name of the author" },
        "authorId": { "type": "string", "description": "Firebase Auth UID of the author" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Server timestamp of last update" }
      },
      "required": ["title", "content", "authorName", "authorId", "createdAt", "updatedAt"]
    },
    "Notice": {
      "title": "Notice",
      "description": "An official announcement or notice",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the notice" },
        "content": { "type": "string", "description": "The markdown content of the notice" },
        "authorName": { "type": "string", "description": "Display name of the author (usually admin)" },
        "authorId": { "type": "string", "description": "Firebase Auth UID of the author" },
        "priority": { "type": "boolean", "description": "Whether to pin this notice to top" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp of creation" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Server timestamp of last update" }
      },
      "required": ["title", "content", "authorName", "authorId", "createdAt", "updatedAt"]
    },
    "Video": {
      "title": "Video",
      "description": "A video resource or archive entry",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the video" },
        "description": { "type": "string", "description": "Detailed description of the video content" },
        "youtubeUrl": { "type": "string", "description": "YouTube URL or ID" },
        "thumbnail": { "type": "string", "description": "Optional thumbnail URL" },
        "authorName": { "type": "string", "description": "Author name" },
        "authorId": { "type": "string", "description": "Author UID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Update timestamp" }
      },
      "required": ["title", "youtubeUrl", "authorName", "authorId", "createdAt", "updatedAt"]
    },
    "Event": {
      "title": "Event",
      "description": "An event or campaign organized by the coalition",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the event or campaign" },
        "type": { "type": "string", "enum": ["event", "campaign"], "description": "Type: event or campaign" },
        "description": { "type": "string", "description": "Detailed description" },
        "status": { "type": "string", "enum": ["scheduled", "active", "completed"], "description": "Status of event" },
        "startDate": { "type": "string", "description": "Start date (YYYY-MM-DD)" },
        "endDate": { "type": "string", "description": "End date (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Time description e.g. 14:00 - 16:00" },
        "location": { "type": "string", "description": "Location details" },
        "imageUrl": { "type": "string", "description": "Promotion banner image URL" },
        "authorId": { "type": "string", "description": "Author's Auth UID" },
        "authorName": { "type": "string", "description": "Author's display name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last updated timestamp" }
      },
      "required": ["title", "type", "description", "status", "startDate", "endDate", "time", "location", "authorId", "authorName", "createdAt", "updatedAt"]
    },
    "Rsvp": {
      "title": "Rsvp",
      "description": "An RSVP registration for an event",
      "type": "object",
      "properties": {
        "eventId": { "type": "string", "description": "The target event ID" },
        "name": { "type": "string", "description": "Full name of the registrant" },
        "phone": { "type": "string", "description": "Phone number of the registrant" },
        "email": { "type": "string", "description": "Email address of the registrant" },
        "message": { "type": "string", "description": "Optional notes or message" },
        "userId": { "type": "string", "description": "Auth UID of the registrant, if logged in" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of register action" }
      },
      "required": ["eventId", "name", "phone", "email", "createdAt"]
    }
  },
  "firestore": {
    "posts/{postId}": {
      "schema": "Post",
      "description": "Collection of board posts"
    },
    "notices/{noticeId}": {
      "schema": "Notice",
      "description": "Collection of official notices"
    },
    "videos/{videoId}": {
      "schema": "Video",
      "description": "Collection of video resources"
    },
    "events/{eventId}": {
      "schema": "Event",
      "description": "Collection of events and campaigns"
    },
    "events/{eventId}/rsvps/{rsvpId}": {
      "schema": "Rsvp",
      "description": "Sub-collection of registrations for a given event"
    }
  }
}
